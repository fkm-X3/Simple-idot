/// python translations ///

// functions //
fn area(r) => {
    let pi = 3.14
    pi * r * r
}
 

// quick loops //
repeat 5{
    print("Hello")
}

// variables and reasignment //
let x = 5
re let x = 10

~ "let" asigns X with the number "5" like putting it into a box for later use ~
~ "re let" reasigns the variable to "10" ~